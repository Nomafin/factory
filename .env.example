ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...
FACTORY_AUTH_TOKEN=your-secret-token-here
PLANE_API_KEY=pl_...

# Agent memory (optional — omit to disable)
SURREALDB_URL=ws://localhost:8200/rpc
SURREALDB_USER=root
SURREALDB_PASS=your-surrealdb-password

# Vector search embeddings (optional — omit for BM25 full-text search only)
OPENAI_API_KEY=sk-...

# Plane OAuth (optional — omit to disable dashboard authentication)
PLANE_OAUTH_CLIENT_ID=
PLANE_OAUTH_CLIENT_SECRET=
PLANE_OAUTH_REDIRECT_URI=http://localhost:8100/auth/callback
SESSION_SECRET=change-me-to-a-random-string
