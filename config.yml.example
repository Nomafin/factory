max_concurrent_agents: 3
agent_timeout_minutes: 30

plane:
  base_url: "https://your-plane-instance.example.com"
  api_key: ""  # Or set PLANE_API_KEY env var
  workspace_slug: "your-workspace"
  project_id: "your-project-uuid"
  states:
    in_progress: "your-state-uuid"
    in_review: "your-state-uuid"
    done: "your-state-uuid"
    failed: "your-state-uuid"
    cancelled: "your-state-uuid"

orchestrator:
  host: "0.0.0.0"
  port: 8100
  auth_token: ""  # Or set FACTORY_AUTH_TOKEN env var

repos:
  my-repo:
    url: "https://github.com/your-org/your-repo.git"
    default_agent: "coder"

agent_templates:
  coder:
    system_prompt_file: "prompts/coder.md"
    allowed_tools:
      - "Read"
      - "Edit"
      - "Bash"
      - "Glob"
      - "Grep"
    timeout_minutes: 30
  reviewer:
    system_prompt_file: "prompts/reviewer.md"
    allowed_tools:
      - "Read"
      - "Glob"
      - "Grep"
    timeout_minutes: 15
  researcher:
    system_prompt_file: "prompts/researcher.md"
    allowed_tools:
      - "WebSearch"
      - "WebFetch"
      - "Read"
    timeout_minutes: 20
  devops:
    system_prompt_file: "prompts/devops.md"
    allowed_tools:
      - "Bash"
      - "Read"
      - "Edit"
    timeout_minutes: 15
